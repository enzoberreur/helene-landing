# Copy this file to .env and fill in the values.
# In Vercel: add these as Environment Variables in Project Settings.

# Notion integration token (starts with "secret_")
# Create one at: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# ID of the Notion database to write waitlist entries into
# Copy from the database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=...
